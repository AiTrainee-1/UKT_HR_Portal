# Copy to .env and adjust

DB_HOST=host
DB_PORT=5432
DB_NAME=db_name
DB_USER=postgres
DB_PASSWORD=password

HR_USERNAME=admin
HR_PASSWORD=admin123

JWT_SECRET=uk-textile-jwt-secret-change-in-production
DJANGO_SECRET_KEY=django-dev-secret-change-in-production

DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend dev servers (Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:23805,http://127.0.0.1:5173

# Biometric — eSSL e2008 (ZK/ICLOCK protocol, pulled by server via pyzk)
# Find the device IP: Main Menu → COMM. → Ethernet → IP Address
BIOMETRIC_DEVICE_IP=192.168.0.XXX
BIOMETRIC_DEVICE_PORT=4370
BIOMETRIC_DEVICE_PASSWORD=0

# HTTP-push API key (not used by eSSL e2008 pull approach — reserved for future)
BIOMETRIC_API_KEY=change-this-to-a-strong-random-key
