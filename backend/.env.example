# Copy to .env and adjust

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uk_textile

HR_USERNAME=admin
HR_PASSWORD=admin123

JWT_SECRET=uk-textile-jwt-secret-change-in-production
DJANGO_SECRET_KEY=django-dev-secret-change-in-production

DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend dev servers (Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:23805,http://127.0.0.1:5173

# Biometric device API key — must match X-Device-Key header sent by AiFace-Mars
BIOMETRIC_API_KEY=change-this-to-a-strong-random-key
